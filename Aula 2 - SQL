-- Criar tabela de clientes
CREATE TABLE clientes (
    id INT PRIMARY KEY,
    nome VARCHAR(100)
);

-- Criar tabela de pedidos
CREATE TABLE pedidos (
    id INT PRIMARY KEY,
    nome_cliente VARCHAR(100),
    valor DECIMAL(10,2)
);

