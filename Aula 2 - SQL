('Kaun David Leal',1614)
;  

UPDATE Funcionario 
	set salario = 1650 
	WHERE id = 2;
	
UPDATE Funcionario 
	set nome = 'Peleleca TI' 
	WHERE id = 1;



CREATE OR REPLACE FUNCTION Registrar_Log_Alteração_de_Salario()
RETURNS TRIGGER AS $$
BEGIN
	INSERT INTO Funcionario_log (id_funcionario, salario_antigo,salario_novo, data_alteracao) 
  	VALUES (new.id,old.salario,new.salario, now()); 
RETURN NEW; 
END; $$ LANGUAGE plpgsql;   
 
CREATE TRIGGER Rastrear_Alteração_de_Nome
AFTER UPDATE 
ON Funcionario
FOR EACH ROW
WHEN (old.nome <> new.nome)
EXECUTE FUNCTION Registrar_Log_Alteração_de_Nome();



CREATE OR REPLACE FUNCTION Registrar_Log_Alteração_de_Nome()
RETURNS TRIGGER AS $$
BEGIN
	INSERT INTO Funcionario_log (id_funcionario, nome_antigo,nome_novo, data_alteracao) 
  	VALUES (new.id,old.nome,new.nome, now()); 
RETURN NEW; 
END; $$ LANGUAGE plpgsql;   
 
CREATE TRIGGER Rastrear_Alteração_de_Nome
AFTER UPDATE 
ON Funcionario
FOR EACH ROW
WHEN (old.salario <> new.salario)
EXECUTE FUNCTION Registrar_Log_Alteração_de_Salario();
